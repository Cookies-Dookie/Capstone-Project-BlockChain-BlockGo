{
    "name": "registrar-network",
    "version": "1.0.0",
    "client": {
        "organization": "Org1",
        "connection": {
            "timeout": {
                "peer": {
                    "endorser": "300"
                }
            }
        }
    },
    "channels": {
        "registrar-channel": {
            "orderers": [
                "orderer.capstone.com"
            ],
            "peers": {
                "peer0.registrar.capstone.com": {
                    "endorsingPeer": true,
                    "chaincodeQuery": true,
                    "ledgerQuery": true,
                    "eventSource": true
                }
            }
        }
    },
    "organizations": {
        "Org1": {
            "mspid": "Org1MSP",
            "peers": [
                "peer0.registrar.capstone.com"
            ],
            "certificateAuthorities": [
                "ca.registrar.capstone.com"
            ]
        }
    },
    "orderers": {
        "orderer.capstone.com": {
            "url": "grpcs://localhost:7050",
            "grpcOptions": {
                "ssl-target-name-override": "orderer.capstone.com"
            },
            "tlsCACerts": {
                "path": "../network/crypto-config/ordererOrganizations/capstone.com/orderers/orderer.capstone.com/tls/ca.crt"
            }
        }
    },
    "peers": {
        "peer0.registrar.capstone.com": {
            "url": "grpcs://localhost:7051",
            "grpcOptions": {
                "ssl-target-name-override": "peer0.registrar.capstone.com"
            },
            "tlsCACerts": {
                "path": "../network/crypto-config/peerOrganizations/registrar.capstone.com/peers/peer0.registrar.capstone.com/tls/ca.crt"
            }
        }
    },
    "certificateAuthorities": {
        "ca.registrar.capstone.com": {
            "url": "https://localhost:7054",
            "caName": "ca-org1",
            "tlsCACerts": {
                "path": "../network/crypto-config/peerOrganizations/registrar.capstone.com/tlsca/tlsca.registrar.capstone.com-cert.pem"
            },
            "httpOptions": {
                "verify": false
            }
        }
    }
}