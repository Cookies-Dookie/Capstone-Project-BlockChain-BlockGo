{
    "name": "registrar-network",
    "version": "1.0.0",
    "client": {
        "organization": "Registrar"
    },
    "organizations": {
        "Registrar": {
            "mspid": "RegistrarMSP",
            "peers": [
                "peer0.registrar.capstone.com"
            ],
            "certificateAuthorities": [
                "ca.registrar.capstone.com"
            ]
        }
    },
    "peers": {
        "peer0.registrar.capstone.com": {
            "url": "grpcs://localhost:7051",
            "tlsCACerts": {
                "path": "crypto-config/peerOrganizations/registrar.capstone.com/peers/peer0.registrar.capstone.com/tls/ca.crt"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer0.registrar.capstone.com"
            }
        }
    },
    "certificateAuthorities": {
        "ca.registrar.capstone.com": {
            "url": "https://localhost:7054",
            "caName": "ca-registrar",
            "tlsCACerts": {
                "path": "crypto-config/peerOrganizations/registrar.capstone.com/ca/ca.registrar.capstone.com-cert.pem"
            },
            "httpOptions": {
                "verify": false
            }
        }
    }
}